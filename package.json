{
  "name": "learn",
  "version": "1.0.0",
  "description": "Node.js week 1 learning project",
  "main": "src/cli/index.js",
  "scripts": {
    "start": "node src/cli/index.js",
    "dev": "node --watch src/cli/index.js",
    "demo:cjs": "node src/demos/week1/module-system/commonjs-demo.js",
    "demo:esm": "node src/demos/week1/module-system/esm-demo.mjs",
    "demo:day2": "node src/demos/week1/runtime/day2-process-path.js",
    "demo:day7": "node src/demos/week1/runtime/day7-review.js",
    "demo:sqlite": "node src/demos/week2/sqlite/sqlite-demo.js",
    "demo:sqlite-query": "node src/demos/week2/sqlite/sqlite-query-demo.js",
    "demo:sqlite-advanced": "node src/demos/week2/sqlite/sqlite-advanced-query-demo.js",
    "demo:sqlite-blog": "node src/demos/week2/sqlite/sqlite-blog-demo.js",
    "demo:sqlite-aggregate": "node src/demos/week2/sqlite/sqlite-join-aggregate-demo.js",
    "demo:sqlite-having-sort": "node src/demos/week2/sqlite/sqlite-having-sort-demo.js",
    "demo:sqlite-post-stats-page": "node src/demos/week2/sqlite/sqlite-post-stats-page-demo.js",
    "demo:fs": "node src/demos/week1/runtime/fs-demo.js",
    "demo:http": "node src/demos/week1/http/http-server.js --demo",
    "curl:get-users": "curl -s http://127.0.0.1:4000/users",
    "curl:get-posts": "curl -s http://127.0.0.1:4000/posts",
    "curl:search-posts": "curl -s \"http://127.0.0.1:4000/posts/search?keyword=SQLite&page=1&pageSize=3&sortBy=created_at&sortOrder=DESC\"",
    "curl:search-posts-advanced": "curl -s -X POST http://127.0.0.1:4000/posts/search-advanced -H \"Content-Type: application/json\" -d '{\"keywords\":[\"SQLite\",\"Query\"],\"authorIds\":[1],\"page\":1,\"pageSize\":5,\"sortBy\":\"created_at\",\"sortOrder\":\"DESC\"}'",
    "curl:get-post-by-id": "curl -s http://127.0.0.1:4000/posts/1",
    "curl:get-post-comments": "curl -s http://127.0.0.1:4000/posts/1/comments",
    "curl:create-post": "curl -s -X POST http://127.0.0.1:4000/posts -H \"Content-Type: application/json\" -d '{\"userId\":1,\"title\":\"API创建文章\",\"content\":\"这是通过接口创建的文章\"}'",
    "curl:update-post": "curl -s -X PUT http://127.0.0.1:4000/posts/1 -H \"Content-Type: application/json\" -d '{\"title\":\"更新后的文章标题\"}'",
    "curl:delete-post": "curl -s -X DELETE http://127.0.0.1:4000/posts/1",
    "curl:create-comment": "curl -s -X POST http://127.0.0.1:4000/comments -H \"Content-Type: application/json\" -d '{\"postId\":1,\"userId\":1,\"content\":\"这是通过接口创建的评论\"}'",
    "curl:update-comment": "curl -s -X PUT http://127.0.0.1:4000/comments/1 -H \"Content-Type: application/json\" -d '{\"content\":\"更新后的评论内容\"}'",
    "curl:delete-comment": "curl -s -X DELETE http://127.0.0.1:4000/comments/1",
    "curl:get-post-stats": "curl -s \"http://127.0.0.1:4000/posts/stats?page=1&pageSize=5&minComments=1&sortBy=comment_count&sortOrder=DESC\"",
    "curl:health": "curl -s http://127.0.0.1:4000/health",
    "serve:express": "node src/app/server.js",
    "test": "node --test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1",
    "sqlite3": "^5.1.7"
  }
}
